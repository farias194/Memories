{%- assign upsell_field = closest.product.metafields.custom.brooklyn-souvenir -%}
{% if upsell_field and upsell_field.value %}
  {%- assign upsell = upsell_field.value -%}
  <div id="UpsellBlock-{{ block.id }}-{{ section.id }}" class="upsell-block" {{ block.shopify_attributes }}>
    {% render 'upsell-bundle',
       upsell: upsell,
       section_id: section.id,
       block_id: block.id %}
  </div>
{% else %}
  {%- comment -%} no upsell configured for this product — render nothing {%- endcomment -%}
{% endif %}

{% schema %}
{
  "name": "Upsell bundle",
  "settings": [],
  "presets": [
    {
      "name": "Upsell bundle"
    }
  ]
}
{% endschema %}