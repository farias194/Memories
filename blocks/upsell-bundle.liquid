
<div class="upsell-wrapper-debug">
  WRAPPER LOADED — closest.product present?
  {% if closest.product %}true{% else %}false{% endif %}
</div>




{%- assign upsell = closest.product.metafields.custom.product_bundle.value -%}
{% if upsell %}
  <div id="UpsellBlock-{{ block.id }}-{{ section.id }}" {{ block.shopify_attributes }}>
    {% render 'upsell-bundle', upsell: upsell, section_id: section.id, block_id: block.id %}
  </div>
{% endif %}



{% schema %}
{
  "name": "Upsell bundle",
  "settings": [],
  "presets": [
    {
      "name": "Upsell bundle"
    }
  ]
}
{% endschema %}


{%- assign mf = closest.product.metafields.custom.product_bundle -%}

<script>
  console.log('DEBUG: product context present? {% if closest.product %}true{% else %}false{% endif %}');
  console.log('DEBUG: metafield object present? {% if mf %}true{% else %}false{% endif %}');
  console.log('DEBUG: metafield value present? {% if mf and mf.value %}true{% else %}false{% endif %}');
  {% if mf and mf.value %}
    console.log('DEBUG: upsell id: {{ mf.value.id }}');
    console.log('DEBUG: upsell title: {{ mf.value.title | escape }}');
    {% comment %} If the metaobject contains product refs, print their count safely {% endcomment %}
    {% if mf.value.products and mf.value.products.value %}
      console.log('DEBUG: upsell products count: {{ mf.value.products.value.size }}');
    {% endif %}
  {% endif %}
</script>