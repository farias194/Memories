{% doc %}
  @prompt
    a section with contains an image block with settings to make this image block contain either one or two images. setting to set these images either horizontally or vertically
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-block__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    width: 100%;
    {% if block.settings.layout == 'vertical' %}
      flex-direction: column;
    {% else %}
      flex-direction: row;
    {% endif %}
  }

  .ai-image-block__image-wrapper-{{ ai_gen_id }} {
    {% if block.settings.image_count == '1' %}
      width: 100%;
    {% else %}
      {% if block.settings.layout == 'horizontal' %}
        flex: 1;
      {% else %}
        width: 100%;
      {% endif %}
    {% endif %}
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-block__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    {% if block.settings.aspect_ratio != 'natural' %}
      aspect-ratio: {{ block.settings.aspect_ratio }};
    {% endif %}
  }

  .ai-image-block__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    {% if block.settings.aspect_ratio != 'natural' %}
      aspect-ratio: {{ block.settings.aspect_ratio }};
    {% else %}
      min-height: 400px;
    {% endif %}
  }

  .ai-image-block__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-block__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-block__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'vertical' %}
        flex-direction: column;
      {% else %}
        flex-direction: row;
      {% endif %}
    }

    .ai-image-block__image-wrapper-{{ ai_gen_id }} {
      {% if block.settings.image_count == '2' and block.settings.mobile_layout == 'horizontal' %}
        flex: 1;
      {% else %}
        width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<image-block-{{ ai_gen_id }}
  class="ai-image-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-block__container-{{ ai_gen_id }}">
    <div class="ai-image-block__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_1 %}
        <img
          src="{{ block.settings.image_1 | image_url: width: 2000 }}"
          alt="{{ block.settings.image_1.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_1.width }}"
          height="{{ block.settings.image_1.height }}"
          class="ai-image-block__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-block__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-block__empty-state-{{ ai_gen_id }}">
            Add your first image
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.image_count == '2' %}
      <div class="ai-image-block__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 2000 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="ai-image-block__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-block__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-block__empty-state-{{ ai_gen_id }}">
              Add your second image
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</image-block-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Image block",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_count",
      "label": "Number of images",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "vertical"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "First image"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Second image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "natural",
          "label": "Natural"
        },
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Widescreen (16:9)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        }
      ],
      "default": "natural"
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Gap between images",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image block"
    }
  ]
}
{% endschema %}