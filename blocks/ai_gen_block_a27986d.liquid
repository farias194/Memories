{% doc %}
  @prompt
    custom multi column section that allows for the adding of rows as well as columns
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-multi-column-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-multi-column-grid__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.row_gap }}px;
  }

  .ai-multi-column-grid__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-multi-column-grid__cell-{{ ai_gen_id }} {
    background-color: {{ block.settings.cell_background_color }};
    padding: {{ block.settings.cell_padding }}px;
    border-radius: {{ block.settings.cell_border_radius }}px;
    border: {{ block.settings.cell_border_width }}px solid {{ block.settings.cell_border_color }};
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-multi-column-grid__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-multi-column-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-multi-column-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-multi-column-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-multi-column-grid__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-multi-column-grid__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-multi-column-grid__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    transition: background-color 0.3s ease;
  }

  .ai-multi-column-grid__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-multi-column-grid__row-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-multi-column-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<multi-column-grid-{{ ai_gen_id }} class="ai-multi-column-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-multi-column-grid__container-{{ ai_gen_id }}">
    {% for row_index in (1..3) %}
      {% liquid
        assign row_enabled_key = 'row_' | append: row_index | append: '_enabled'
        assign row_enabled = block.settings[row_enabled_key]
      %}

      {% if row_enabled %}
        <div class="ai-multi-column-grid__row-{{ ai_gen_id }}">
          {% for col_index in (1..4) %}
            {% liquid
              assign cell_key_prefix = 'row_' | append: row_index | append: '_col_' | append: col_index
              assign image_key = cell_key_prefix | append: '_image'
              assign heading_key = cell_key_prefix | append: '_heading'
              assign text_key = cell_key_prefix | append: '_text'
              assign button_text_key = cell_key_prefix | append: '_button_text'
              assign button_link_key = cell_key_prefix | append: '_button_link'

              assign cell_image = block.settings[image_key]
              assign cell_heading = block.settings[heading_key]
              assign cell_text = block.settings[text_key]
              assign cell_button_text = block.settings[button_text_key]
              assign cell_button_link = block.settings[button_link_key]
            %}

            {% if col_index <= block.settings.columns_desktop %}
              <div class="ai-multi-column-grid__cell-{{ ai_gen_id }}">
                {% if cell_image != blank %}
                  <div class="ai-multi-column-grid__image-wrapper-{{ ai_gen_id }}">
                    <img
                      src="{{ cell_image | image_url: width: 600 }}"
                      alt="{{ cell_image.alt | escape }}"
                      class="ai-multi-column-grid__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="{{ cell_image.width }}"
                      height="{{ cell_image.height }}"
                    >
                  </div>
                {% else %}
                  <div class="ai-multi-column-grid__image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if cell_heading != blank %}
                  <h3 class="ai-multi-column-grid__heading-{{ ai_gen_id }}">{{ cell_heading }}</h3>
                {% endif %}

                {% if cell_text != blank %}
                  <div class="ai-multi-column-grid__text-{{ ai_gen_id }}">{{ cell_text }}</div>
                {% endif %}

                {% if cell_button_text != blank %}
                  <a
                    href="{{ cell_button_link | default: '#' }}"
                    class="ai-multi-column-grid__button-{{ ai_gen_id }}"
                  >
                    {{ cell_button_text }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</multi-column-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class MultiColumnGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('multi-column-grid-{{ ai_gen_id }}', MultiColumnGrid{{ ai_gen_id }});
  })();
</script>

