
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    margin: 0 auto;
    position: relative;
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-timeline-line-wrapper-{{ ai_gen_id }} {
    position: absolute;
    right: 50%;
    top: 0;
    bottom: 0;
    width: {{ section.settings.lsjopine_width }}px;
    z-index: -1;
    pointer-events: none;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
    background-color: {{ section.settings.line_color }};
    overflow: hidden;
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ section.settings.line_active_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: calc({{ section.settings.line_position }}px + 40px);
    margin-bottom: 60px;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    right: calc(50% - 10px);
    top: 0;
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color }};
    border: {{ section.settings.dot_border_width }}px solid {{ section.settings.dot_border_color }};
    transition: all 0.3s ease;
    z-index: 3;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background-color: {{ section.settings.dot_active_color }};
    border-color: {{ section.settings.dot_active_border_color }};
    transform: scale({{ section.settings.dot_active_scale }});
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ section.settings.content_bg_color }};
    padding: {{ section.settings.content_padding }}px;
    border-radius: {{ section.settings.content_border_radius }}px;
    opacity: {{ section.settings.content_inactive_opacity }};
    transform: translateX(20px);
    transition: all 0.5s ease;
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateX(0);
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    color: {{ section.settings.date_color }};
    font-size: {{ section.settings.date_font_size }}px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_font_size }}px;
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_font_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  /*@media screen and (max-width: 749px) {
    .ai-timeline-line-wrapper-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 60px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: calc(20px - {{ section.settings.dot_size | divided_by: 2 }}px);
    }
  }*/
{% endstyle %}

<scroll-timeline-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}">
  <div class="ai-timeline-container-{{ ai_gen_id }}">

    <div class="ai-timeline-line-wrapper-{{ ai_gen_id }}">
      <div class="ai-timeline-line-{{ ai_gen_id }}">
        <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
      </div>
    </div>

    {% for block in section.blocks %}
      <div
        class="ai-timeline-item-{{ ai_gen_id }}"
        data-timeline-item
        {{ block.shopify_attributes }}
      >
        <div class="ai-timeline-dot-{{ ai_gen_id }}"></div>

        <div class="ai-timeline-content-{{ ai_gen_id }}">
          {% if block.settings.date != blank %}
            <div class="ai-timeline-date-{{ ai_gen_id }}">
              {{ block.settings.date }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="ai-timeline-title-{{ ai_gen_id }}">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="ai-timeline-description-{{ ai_gen_id }}">
              {{ block.settings.description }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</scroll-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollTimeline  extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.timelineLine = null;

        this.handleScroll = this.updateTimeline.bind(this);
      }

      connectedCallback() {
        this.items = Array.from(
          this.querySelectorAll('[data-timeline-item]')
        );

        this.progressBar = this.querySelector(
          '.ai-timeline-progress-{{ ai_gen_id }}'
        );

        this.timelineLine = this.querySelector(
          '.ai-timeline-line-wrapper-{{ ai_gen_id }}'
        );

        if (this.items.length > 0) {
          this.setupScrollListener();
          this.updateTimeline();
        }
      }

      setupScrollListener() {
        window.addEventListener('scroll', this.handleScroll);
        window.addEventListener('resize', this.handleScroll);
      }

    updateTimeline() {
  const windowHeight = window.innerHeight;
const timelineHeight = this.timelineLine.offsetHeight;
  let maxProgress = 0;

  this.items.forEach((item) => {
    const itemRect = item.getBoundingClientRect();
    const itemMiddle = itemRect.top + (itemRect.height / 2);

    const triggerPoint = windowHeight * 0.7;

    if (itemMiddle < triggerPoint) {
      item.classList.add('active');

      const itemPosition = item.offsetTop;
      const progress = (itemPosition / timelineHeight) * 100;

      maxProgress = Math.max(maxProgress, progress);
    } else {
      item.classList.remove('active');
    }
  });

  if (this.progressBar) {
    this.progressBar.style.height =
      Math.min(maxProgress, 100) + '%';
  }
}

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
        window.removeEventListener('resize', this.handleScroll);
      }
    }

    customElements.define(
      'scroll-timeline-{{ ai_gen_id }}',
      ScrollTimeline{{ ai_gen_id }}
    );
  })();
  console.log({{ ai_gen_id }});
</script>

