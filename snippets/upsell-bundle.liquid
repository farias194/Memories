{%- comment -%}
UPSELL BUNDLE COMPONENT (UI layer)
Receives:
- upsell (metaobject)
- section_id
{%- endcomment -%}

<div class="upsell-bundle upsell-bundle--{{ upsell.theme | default: 'default' }}">

  <label class="upsell-bundle__label">

    <input
      type="checkbox"
      class="upsell-bundle__checkbox"
      id="Upsell-{{ section_id }}"
    >

    <div class="upsell-bundle__content">

      {% if upsell.badge %}
        <span class="upsell-bundle__badge">
          {{ upsell.badge }}
        </span>
      {% endif %}

      <h3 class="upsell-bundle__title">
        {{ upsell.heading }}
      </h3>

      {% if upsell.description %}
        <div class="upsell-bundle__desc">
          {{ upsell.description }}
        </div>
      {% endif %}

      <ul class="upsell-bundle__items">

        {% for product in upsell.products.value %}

          <li class="upsell-bundle__item">

            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 120 }}"
                alt="{{ product.title }}"
              >
            {% endif %}

            <div>
              <p>{{ product.title }}</p>
              <p>{{ product.price | money }}</p>
            </div>

          </li>

        {% endfor %}

      </ul>

    </div>

  </label>

</div>

<script>

document.addEventListener('DOMContentLoaded', () => {

  const checkbox = document.getElementById('Upsell-{{ section_id }}');

  if (!checkbox) return;

  checkbox.addEventListener('change', async () => {

    if (!checkbox.checked) return;

    const items = [

      {% for product in upsell.products.value %}

        {
          id: {{ product.selected_or_first_available_variant.id }},
          quantity: 1
        }

        {% unless forloop.last %},{% endunless %}

      {% endfor %}

    ];

    await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items })
    });

  });

});

</script>