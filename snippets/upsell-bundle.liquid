{%- comment -%}
Receives:
- upsell (metaobject) or nil
- section_id
- block_id
{%- endcomment -%}
<div class="upsell-debug">SNIPPET LOADED — upsell present? {{ upsell != nil }}</div>



{%- if upsell -%}
<div class="upsell-bundle upsell-bundle--{{ upsell.theme | default: 'default' }}">
  <label class="upsell-bundle__label">
    <input
      type="checkbox"
      class="upsell-bundle__checkbox"
      id="Upsell-{{ section_id }}-{{ block_id }}"
    >

    <div class="upsell-bundle__content">
    
      <h3 class="upsell-bundle__title">{{ upsell.heading }}</h3>

      {% if upsell.description %}
        <div class="upsell-bundle__desc">{{ upsell.description }}</div>
      {% endif %}

      {% if upsell.products and upsell.products.value and upsell.products.value.size > 0 %}
        <ul class="upsell-bundle__items">
          {% for product in upsell.products.value %}
            <li class="upsell-bundle__item">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: 120 }}" alt="{{ product.title }}">
              {% endif %}
              <div>
                <p>{{ product.title }}</p>
                <p>
                  {% if product.price %}{{ product.price | money }}
                  {% elsif product.selected_or_first_available_variant %}
                    {{ product.selected_or_first_available_variant.price | money }}
                  {% endif %}
                </p>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="upsell-empty">No products in this bundle.</p>
      {% endif %}

    </div>
  </label>
</div>

<script>
(function initUpsell() {
  const id = 'Upsell-{{ section_id }}-{{ block_id }}';
  function bind() {
    const checkbox = document.getElementById(id);
    if (!checkbox) return;
    checkbox.addEventListener('change', async () => {
      if (!checkbox.checked) return;
      const items = [
        {% for product in upsell.products.value %}
          {
            id: {{ product.selected_or_first_available_variant.id }},
            quantity: 1
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ];
      if (items.length === 0) return;
      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });
      } catch (err) {
        console.error('Upsell add error', err);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bind);
  } else {
    bind();
  }
})();
</script>
{%- endif -%}